# Mintly Environment Variables
# Copy this file to .env.local and fill in real values

# --- Supabase (get from https://supabase.com/dashboard/project/_/settings/api) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# --- Sphere SDK / Unicity testnet2 ---
# Public testnet2 oracle API key (safe to expose in client code)
NEXT_PUBLIC_SPHERE_ORACLE_API_KEY=sk_ddc3cfcc001e4a28ac3fad7407f99590
# Wallet-api base URL for v2 testnet2
NEXT_PUBLIC_SPHERE_WALLET_API_URL=https://wallet-api.unicity.network
# Network name: testnet or testnet2 (they are aliases)
NEXT_PUBLIC_SPHERE_NETWORK=testnet
# App display name sent in ConnectClient handshake
NEXT_PUBLIC_SPHERE_APP_NAME=Mintly

# --- Agent (used by GitHub Actions + scripts/agent-run.ts) ---
# Same Supabase credentials but SERVER-SIDE ONLY for the agent
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key

# --- Sphere agent wallet (for the autonomous pricing/settlement agent) ---
# A 12-word BIP39 mnemonic for the agent's own Sphere wallet
AGENT_WALLET_MNEMONIC=word1 word2 word3 word4 word5 word6 word7 word8 word9 word10 word11 word12
AGENT_WALLET_NAMETAG=mintly-agent
SPHERE_ORACLE_API_KEY=sk_ddc3cfcc001e4a28ac3fad7407f99590
SPHERE_WALLET_API_URL=https://wallet-api.unicity.network
SPHERE_NETWORK=testnet
